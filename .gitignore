###############################################################################
# Brand assets — NEVER commit the client's proprietary template or any deck.
# (Public repo: these must be ignored from the FIRST commit, or they leak via
#  git history even after deletion.)
###############################################################################
assets/*.pptx
assets/*.potx
*.pptx
!docs/**/*.pptx          # (optional) allow sample/figure decks under docs/ if you add any
outputs/
runs/

###############################################################################
# Secrets & local config
###############################################################################
.env
.env.*
!.env.example
*.key
*.pem
# Google ADC / service-account creds — never commit
**/application_default_credentials.json
*service-account*.json
gha-creds-*.json

###############################################################################
# Python
###############################################################################
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.ipynb_checkpoints/

###############################################################################
# Generated / scratch artifacts (renderer working dirs, images, PDFs)
###############################################################################
work/
unpacked/
*_unpacked/
gen/
media_fitted/
*.pdf
slide-*.jpg
thumbnails-*.jpg

###############################################################################
# DeepEval (external test layer)
###############################################################################
.deepeval/
.deepeval-cache/
*.deepeval

###############################################################################
# Node / frontend (if Antigravity / Claude Design output lands in frontend/)
###############################################################################
node_modules/
frontend/dist/
frontend/.vite/
*.log

###############################################################################
# OS / editor
###############################################################################
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
